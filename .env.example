# =============================================================================
# Hermes Agent — Environment Configuration
# Copy to .env and fill in values. Never commit .env to version control.
# =============================================================================

# --- Data directories ---
# macOS/Linux: use absolute paths (e.g. /Users/yourname/.hermes)
# Windows (WSL2): use Linux-style paths (e.g. /c/Users/YourName/.hermes)
HERMES_DATA_DIR=~/.hermes
HERMES_WORKSPACE_DIR=~/.hermes/workspace

# --- Network ---
# Ports are bound to HERMES_BIND_ADDR only.
# 127.0.0.1 = localhost-only (recommended, most secure)
# 0.0.0.0   = all interfaces (only if LAN/remote access is required)
HERMES_BIND_ADDR=127.0.0.1
HERMES_GATEWAY_PORT=8642
HERMES_DASHBOARD_PORT=9119

# --- LLM API Keys ---
# Add keys only for the providers you intend to use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Resource limits ---
HERMES_MEMORY_LIMIT=4G
HERMES_CPU_LIMIT=2.0
HERMES_DASHBOARD_MEMORY_LIMIT=512M
HERMES_DASHBOARD_CPU_LIMIT=0.5

# --- Shared memory for Playwright/browser tools ---
# Increase to 2g if you enable browser automation skills.
HERMES_SHM_SIZE=1g
